      "cccccccc-cccc-cccc-cccc-cccccccccccc": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Top 10 span names",
            "description": "Top span names by count across GenAI spans."
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              }
            }
          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "traces",
                          "stepInterval": 60,
                          "disabled": false,
                          "filter": {
                            "expression": "gen_ai.system != ''"
                          },
                          "groupBy": [
                            {
                              "name": "name",
                              "fieldDataType": "string",
                              "fieldContext": "tag"
                            }
                          ],
                          "limit": 10,
                          "order": [
                            {
                              "key": {
                                "name": "count()"
                              },
                              "direction": "desc"
                            }
                          ],
                          "legend": "{{name}}",
                          "having": {
                            "expression": ""
                          },
                          "aggregations": [
                            {
                              "expression": "count()"
                            }
                          ]
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
