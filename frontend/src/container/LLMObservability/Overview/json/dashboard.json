      "66666666-6666-6666-6666-666666666666": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Cost over time",
            "description": "Cost by model over time."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
              },
              "legend": {
                "position": "bottom"
              },
              "chartAppearance": {
                "lineStyle": "solid",
                "lineInterpolation": "spline",
                "fillMode": "none"
              }
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "traces",
                          "stepInterval": 60,
                          "disabled": false,
                          "filter": {
                            "expression": ""
                          },
                          "groupBy": [
                            {
                              "name": "gen_ai.request.model",
                              "fieldDataType": "string",
                              "fieldContext": "tag"
                            }
                          ],
                          "legend": "{{gen_ai.request.model}}",
                          "having": {
                            "expression": ""
                          },
                          "aggregations": [
