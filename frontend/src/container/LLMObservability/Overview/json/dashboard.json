      },
      "88888888-8888-8888-8888-888888888888": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "LLM call latency percentiles",
            "description": "p50, p90, p95, p99 latency by model."
          },
          "plugin": {
            "kind": "signoz/TablePanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time"
