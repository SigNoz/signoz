          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "traces",
                          "stepInterval": 60,
                          "disabled": false,
                          "filter": {
                            "expression": ""
