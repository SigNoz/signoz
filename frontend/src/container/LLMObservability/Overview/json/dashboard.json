                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "traces",
                          "stepInterval": 60,
                          "disabled": false,
                          "filter": {
                            "expression": "has_error = true AND gen_ai.system != ''"
