          },
          "queries": [
            {
              "kind": "scalar",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "traces",
                          "stepInterval": 60,
                          "disabled": false,
                          "filter": {
                            "expression": "gen_ai.system != ''"
                          },
                          "having": {
                            "expression": ""
                          },
                          "aggregations": [
                            {
                              "expression": "countIf(has_error = true)"
                            },
                            {
                              "expression": "count()"
                            }
                          ]
                        }
                      }
                    ]
                  }
                }
              }
            }
          ]
        }
      },
      "55555555-5555-5555-5555-555555555555": {
        "kind": "Panel",
        "spec": {
