{
  "id": "bugsnag",
  "title": "Bugsnag",
  "description": "Forward Bugsnag error and crash events to SigNoz.",
  "author": {
    "name": "Felipe Duarte",
    "email": "fcduarte@gmail.com",
    "homepage": "https://signoz.io"
  },
  "icon": "file://icon.png",
  "categories": [
    "Error Monitoring",
    "Mobile"
  ],
  "overview": "file://overview.md",
  "configuration": [
    {
      "title": "Prerequisites",
      "instructions": "file://config/prerequisites.md"
    },
    {
      "title": "Forward Error Events",
      "instructions": "file://config/forward-error-events.md"
    }
  ],
  "assets": {
    "logs": {
      "pipelines": []
    },
    "dashboards": [
      "file://assets/dashboards/overview.json"
    ],
    "alerts": null
  },
  "connection_tests": {
    "logs": {
      "attribute_key": "source",
      "attribute_value": "bugsnag"
    }
  },
  "data_collected": {
    "logs": [
      {
        "name": "Timestamp",
        "path": "timestamp",
        "type": "timestamp"
      },
      {
        "name": "Severity Text",
        "path": "severity_text",
        "type": "string"
      },
      {
        "name": "Severity Number",
        "path": "severity_number",
        "type": "number"
      },
      {
        "name": "Trigger Type",
        "path": "attributes.bugsnag.trigger.type",
        "type": "string"
      },
      {
        "name": "Project Name",
        "path": "attributes.bugsnag.project.name",
        "type": "string"
      },
      {
        "name": "Exception Class",
        "path": "attributes.exception.type",
        "type": "string"
      },
      {
        "name": "Exception Message",
        "path": "attributes.exception.message",
        "type": "string"
      },
      {
        "name": "Error Context",
        "path": "attributes.bugsnag.error.context",
        "type": "string"
      },
      {
        "name": "Error Status",
        "path": "attributes.bugsnag.error.status",
        "type": "string"
      },
      {
        "name": "Unhandled",
        "path": "attributes.bugsnag.error.unhandled",
        "type": "bool"
      },
      {
        "name": "Bugsnag Error URL",
        "path": "attributes.bugsnag.error.url",
        "type": "string"
      },
      {
        "name": "App Version",
        "path": "attributes.app.version",
        "type": "string"
      },
      {
        "name": "Release Stage",
        "path": "attributes.bugsnag.release_stage",
        "type": "string"
      },
      {
        "name": "OS Name",
        "path": "attributes.os.name",
        "type": "string"
      },
      {
        "name": "OS Version",
        "path": "attributes.os.version",
        "type": "string"
      },
      {
        "name": "Device Manufacturer",
        "path": "attributes.device.manufacturer",
        "type": "string"
      },
      {
        "name": "Device Model",
        "path": "attributes.device.model.name",
        "type": "string"
      },
      {
        "name": "User ID",
        "path": "attributes.user.id",
        "type": "string"
      }
    ],
    "metrics": []
  }
}
