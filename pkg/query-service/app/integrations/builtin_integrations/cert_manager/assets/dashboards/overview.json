      "multiSelect": true,
      "name": "certificate_name",
      "order": 2,
      "queryValue": "SELECT JSONExtractString(labels, 'name') AS certificate_name FROM signoz_metrics.distributed_time_series_v4_1day WHERE metric_name = 'certmanager_certificate_expiration_timestamp_seconds' AND JSONExtractString(labels, 'namespace') IN {{.namespace}} AND JSONExtractString(labels, 'issuer_name') IN {{.issuer_name}} GROUP BY certificate_name",
      "selectedValue": [],
