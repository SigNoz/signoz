      "multiSelect": true,
      "name": "namespace",
      "order": 0,
      "queryValue": "SELECT JSONExtractString(labels, 'namespace') AS namespace FROM signoz_metrics.distributed_time_series_v4_1day WHERE metric_name = 'certmanager_certificate_expiration_timestamp_seconds' GROUP BY namespace",
      "selectedValue": [],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "issuer_name": {
      "allSelected": true,
