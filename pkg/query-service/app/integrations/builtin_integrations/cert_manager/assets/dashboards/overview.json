      "key": "issuer_name",
      "modificationUUID": "issuer-mod",
      "multiSelect": true,
      "name": "issuer_name",
      "order": 1,
      "queryValue": "SELECT JSONExtractString(labels, 'issuer_name') AS issuer_name FROM signoz_metrics.distributed_time_series_v4_1day WHERE metric_name = 'certmanager_certificate_expiration_timestamp_seconds' AND JSONExtractString(labels, 'namespace') IN {{.namespace}} GROUP BY issuer_name",
      "selectedValue": [],
      "showALLOption": true,
      "sort": "ASC",
      "textboxValue": "",
      "type": "QUERY"
    },
    "certificate_name": {
      "allSelected": true,
