      "name": "topic",
      "order": 1,
      "queryValue": "SELECT JSONExtractString(labels, 'topic') AS topic FROM signoz_metrics.distributed_time_series_v4_1day WHERE metric_name = 'kafka_topic_partitions' GROUP BY topic",
