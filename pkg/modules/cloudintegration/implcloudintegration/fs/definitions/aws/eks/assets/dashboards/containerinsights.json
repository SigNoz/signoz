                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 60,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "aws_ContainerInsights_node_interface_network_rx_dropped_max",
                              "temporality": "",
                              "timeAggregation": "avg",
                              "spaceAggregation": "avg",
                              "reduceTo": "avg"
                            }
                          ],
                          "disabled": false,
                          "filter": {
                            "expression": "(cloud.account.id = $Account AND cloud.region = $Region AND ClusterName IN $Cluster AND NodeName EXISTS)"
                          },
                          "groupBy": [
                            {
                              "name": "NodeName",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
