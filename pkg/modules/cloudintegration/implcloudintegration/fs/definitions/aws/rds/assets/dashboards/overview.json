                  "spec": {
                    "name": "A",
                    "stepInterval": 60,
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "aws_RDS_CPUUtilization_max",
                        "temporality": "",
                        "timeAggregation": "max",
                        "spaceAggregation": "max",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "(cloud.account.id = $Account AND cloud.region = $Region AND DBInstanceIdentifier != '')"
                    },
                    "groupBy": [
                      {
                        "name": "cloud.account.id",
                        "signal": "",
