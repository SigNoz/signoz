    "panels": {
      "5d2e13cb-4a6e-4713-b5a3-4f38b2c43a18": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "% Main Thread CPU Utilisation",
            "description": "% CPU utilisation calculated by rate at which CPU-seconds are consumed by the Redis server main thread, broken down by system/user space."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "%",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "redis.googleapis.com/stats/cpu_utilization_main_thread",
                              "temporality": "",
                              "timeAggregation": "rate",
                              "spaceAggregation": "sum",
                              "reduceTo": "avg"
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "project_id = $project_id AND instance_id in $instance_id AND gcp.resource_type = 'redis_instance'"
                          },
                          "groupBy": [
                            {
                              "name": "node_id",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "role",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            },
                            {
                              "name": "space",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "order": [],
                          "having": {
                            "expression": ""
                          },
                          "functions": [],
                          "legend": "{{node_id}}/{{role}}/{{space}}"
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A * 100",
                          "disabled": false,
                          "legend": "{{node_id}}/{{role}}/{{space}}"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "links": []
        }
      },
