            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_availability_average",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "min",
                        "reduceTo": "avg"
