      "24317132-187d-5eab-6ab8-95b3a3592091": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Average CPU Percentage",
            "description": "Maximum CPU utilization of the managed instance, as a percentage."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "%",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_avg_cpu_percent_maximum",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "azuremonitor.subscription_id = $azuremonitor.subscription_id AND type = 'Microsoft.Sql/managedInstances' AND name = $name "
                    },
                    "groupBy": [
                      {
                        "name": "name",
                        "signal": "",
                        "fieldContext": "",
                        "fieldDataType": "string"
                      }
                    ],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "{{name}}"
                  }
                }
              }
            }
