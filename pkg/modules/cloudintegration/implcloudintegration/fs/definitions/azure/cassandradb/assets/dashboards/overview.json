                      {
                        "name": "name",
                        "signal": "",
                        "fieldContext": "",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "metadata_cassandra_node",
                        "signal": "",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "metadata_request_type",
