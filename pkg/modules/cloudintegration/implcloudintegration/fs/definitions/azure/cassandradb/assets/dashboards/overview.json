              },
              "formatting": {
                "unit": "",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
