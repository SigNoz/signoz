            "description": "Network received bytes"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "By",
                "decimalPrecision": "0"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_rxbytes_total",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "max",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "azuremonitor.subscription_id = $azuremonitor.subscription_id AND type = 'Microsoft.App/containerApps' AND name = $name "
                    },
                    "groupBy": [
                      {
                        "name": "metadata_revisionname",
                        "signal": "",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      },
                      {
                        "name": "metadata_podname",
                        "signal": "",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "order": [],
                    "having": {
                      "expression": ""
