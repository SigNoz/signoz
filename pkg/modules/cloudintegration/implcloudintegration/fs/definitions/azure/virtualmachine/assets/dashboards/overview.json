                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_vmavailabilitymetric_average",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "avg",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "azuremonitor.subscription_id = $azuremonitor.subscription_id AND type = 'Microsoft.Compute/virtualMachines' AND name = $name"
                    },
                    "groupBy": [
                      {
                        "name": "name",
                        "signal": "",
                        "fieldContext": "",
