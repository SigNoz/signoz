      "0018dc0b-c559-49eb-a506-55a13110363a": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Average Memory Usage",
            "description": "The average amount of memory used by the app, in megabytes (MiB)"
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "By",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": 0,
                "softMax": 0,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_averagememoryworkingset_average",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "max",
                        "reduceTo": "avg"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "azuremonitor.subscription_id = $azuremonitor.subscription_id AND azuremonitor.resource_id CONTAINS '/Microsoft.Web/sites/' AND name = $name "
                    },
                    "groupBy": [
                      {
                        "name": "metadata_Instance",
                        "signal": "",
                        "fieldContext": "attribute",
                        "fieldDataType": "string"
                      }
                    ],
                    "order": [],
                    "having": {
                      "expression": ""
                    },
                    "functions": [],
                    "legend": "{{metadata_Instance}}"
                  }
                }
              }
            }
          ],
          "links": []
