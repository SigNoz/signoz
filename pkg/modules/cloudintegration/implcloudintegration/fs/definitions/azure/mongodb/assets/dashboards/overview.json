          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "name": "A",
                "plugin": {
                  "kind": "signoz/BuilderQuery",
                  "spec": {
                    "name": "A",
                    "signal": "metrics",
                    "source": "",
                    "aggregations": [
                      {
                        "metricName": "azure_memorypercent_maximum",
                        "temporality": "",
                        "timeAggregation": "avg",
                        "spaceAggregation": "max"
                      }
                    ],
                    "disabled": false,
                    "filter": {
                      "expression": "azuremonitor.subscription_id = $azuremonitor.subscription_id AND type = 'Microsoft.DocumentDB/mongoClusters' AND name = $name "
